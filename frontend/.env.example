# ──────────────────────────────────────
# Frontend Environment Variables
# Used by: src/lib/axios.ts
# ──────────────────────────────────────

# Backend API URL
# Must include /api prefix since backend routes are mounted under /api
# In development: Next.js proxy (leave empty or set to http://localhost:5000/api)
# In production: Render backend URL
# Variable type: NEXT_PUBLIC_ (exposed to browser)
NEXT_PUBLIC_API_URL=
