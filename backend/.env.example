# ──────────────────────────────────────
# Backend Environment Variables
# Used by: src/config/index.ts
# ──────────────────────────────────────

# Server Configuration
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed CORS origins
# Example: https://petclinic-drekta.vercel.app,https://petclinicghatkopar.vercel.app,https://petclinicghatkopar.com
CORS_ORIGIN=http://localhost:3000,https://petclinic-drekta.vercel.app,https://www.petclinic-drekta.vercel.app

# API route prefix
API_PREFIX=/api

# ──────────────────────────────────────
# Sarvam AI (Chatbot Backend)
# Required in production. Chat falls back to rule-based without this.
# ──────────────────────────────────────
SARVAM_API_KEY=
SARVAM_API_URL=https://api.sarvam.ai/v1/chat

# ──────────────────────────────────────
# Email (SMTP)
# Required in production for appointment confirmations & contact notifications.
# ──────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@petclinicghatkopar.com
CLINIC_EMAIL=info@petclinicghatkopar.com

# ──────────────────────────────────────
# WhatsApp
# Used in chatbot responses and clinic info display.
# This is a display value, not an API key.
# ──────────────────────────────────────
WHATSAPP_NUMBER=+919820465733
